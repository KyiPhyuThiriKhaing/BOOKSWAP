generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  email    String @unique
  password String

  books Book[]
}

model Book {
  id          Int    @id @default(autoincrement())
  title       String
  author      String
  description String?
  status      String @default("Available")

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])
}